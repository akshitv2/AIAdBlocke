{
  "manifest_version": 3,
  "name": "Image Vetting Extension",
  "version": "1.0",
  "permissions": ["declarativeContent"],
  "host_permissions": ["<all_urls>", "https://your-api-endpoint.com/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}